{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "MinTool",
  "version": "3.2.0",
  "author": "Min <the7mincheol@gmail.com>",
  "description": "Toolbox for anything",
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "activeTab",
    "contextMenus",
    "scripting",
    "storage",
    "webNavigation"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "devtools_page": "devtools/devtools.html",
  "action": {
    "default_popup": "popup/popup.html"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "adblock_rules",
        "enabled": true,
        "path": "rules/adblock-rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "js": [
        "utils/content-main/navigation.global.js",
        "services/virtual-fullscreen/content-main.js",
        "services/console-toast/store.js",
        "services/console-toast/styles.js",
        "services/console-toast/ui.js",
        "services/console-toast/content-main.js",
        "utils/vendor/toastify.js"
      ],
      "matches": ["<all_urls>"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "js": ["services/console-toast/content-isolated.js"],
      "matches": ["<all_urls>"],
      "run_at": "document_start"
    },
    {
      "js": [
        "utils/content-isolated/feature-guard.global.js",
        "utils/content-isolated/global.global.js",
        "utils/content-isolated/components.global.js",
        "utils/content-isolated/log.global.js",
        "utils/content-isolated/wait-for-element.global.js",
        "utils/content-isolated/dom.global.js",
        "utils/vendor/toastify.js",
        "services/virtual-fullscreen/content-isolated.js",
        "utils/content-isolated/draggable.global.js",
        "services/dom-tools/content-isolated/style-editor.js",
        "services/dom-tools/content-isolated/eraser.js",
        "services/dom-tools/content-isolated/coverer.js",
        "utils/vendor/vue-min.js"
      ],
      "matches": ["<all_urls>"]
    },
    {
      "js": ["utils/content-isolated/iframe-contextmenu-reporter.global.js"],
      "matches": ["<all_urls>"],
      "all_frames": true
    },
    {
      "js": [
        "services/github/content-isolated/context.js",
        "services/github/content-isolated/auto-refresh.js",
        "services/github/content-isolated/notification-filters.js",
        "services/github/content-isolated/comment-shortcut.js",
        "services/github/content-isolated/shortcut.js",
        "services/github/content-isolated/pr-commit-auto-embed.js"
      ],
      "matches": ["<all_urls>"]
    },
    {
      "js": ["services/ad-block/content-isolated.js"],
      "matches": ["<all_urls>"]
    },
    {
      "js": ["services/github/content-isolated/site.js"],
      "matches": ["https://github.com/*"]
    },
    {
      "js": ["services/toss-invest/content-isolated.js"],
      "matches": ["https://tossinvest.com/*"]
    },
    {
      "js": ["services/jira/content-isolated.js"],
      "matches": ["https://*.atlassian.net/*", "https://atlassian.net/*"]
    }
  ]
}
